marimo/_static/
marimo/_lsp/
__marimo__/

# Streamlit
.streamlit/secrets.toml
.idea
# The in-UI documentation components live under ui/components/docs/
# and the operator-facing markdown source lives under primer/user_docs/;
# both are tracked frontend/source, not the gitignored docs/ spec area.
!ui/components/docs/
!ui/components/docs/**

# docs/ spec + working areas are kept untracked (only docs/dev/ is tracked
# dev documentation). Keeps generated/working specs, plans and findings out
# of the repo.
docs/tests/
docs/superpowers/

# E2E test harness runtime scratch (logs, rendered config, pidfile).
# Python test code under tests/e2e/ IS versioned; the .e2e/ scratch dir
# and the markdown state file under tests/e2e/.state/ are not — per the
# rule that only code and Python tests are committed.
tests/.e2e/
tests/e2e/.state/
tests/ui_e2e/.state/

# User-filled test configuration (the .example template is versioned).
tests/testconfig.yaml
# Docs embed harness build output: the console JSX bundle is built offline at
# capture time (scripts/docs/capture_embeds.py) and the embed PNGs land under
# dist/ (already ignored). Neither is source.
scripts/docs/embed_harness/_app.js

# local channel/test credentials (never commit)
.credentials
.superpowers/

# Local dogfood deployment config (internal-only; never ship in a public repo).
dogfood/

# Coordinator planning / review / findings docs - working notes only, never
# committed (same rule as docs/superpowers/). Kept on disk for the session.
REMEDIATION-QUEUE.md
CRITICAL-REVIEW-*.md
progress.md
config.local.yaml
MARKETING-*.md
MARKETING.md
OSS-*.md
LAUNCH-*.md
OPEN-SOURCE-LAUNCH-STRATEGY.md
docs/OPEN-SOURCE-LAUNCH-STRATEGY.md
docs/.launch/

# Local clone of the docs Pages repo (deployed separately)
/primerhq.github.io/
